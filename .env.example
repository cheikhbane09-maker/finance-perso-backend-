PORT=3000
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=1d

# Base de donnees : "sqlite" (par defaut, aucune installation) ou "mysql" (via XAMPP)
DB_TYPE=sqlite
DB_PATH=db.sqlite

# Parametres MySQL - utilises uniquement si DB_TYPE=mysql (voir README, section XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=finance_perso
