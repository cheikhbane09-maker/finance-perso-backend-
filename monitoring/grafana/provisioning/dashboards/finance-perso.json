{
  "title": "Finance Perso - Backend",
  "uid": "finance-perso-backend",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Requetes HTTP / seconde",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(finance_perso_http_requests_total[1m])) by (route, status)",
          "legendFormat": "{{route}} ({{status}})"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memoire utilisee (process)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "memoire (bytes)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Event loop lag (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "lag"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU (secondes totales)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "cpu"
        }
      ]
    }
  ]
}
